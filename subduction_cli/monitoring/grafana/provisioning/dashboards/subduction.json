      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "id": 25,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "none" }, "overrides": [{ "matcher": { "id": "byName", "options": "pushes/s" }, "properties": [{ "id": "unit", "value": "ops" }] }] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_subscribed_sedimentrees", "legendFormat": "subscribed trees", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_subscription_pushes_total[1m])", "legendFormat": "pushes/s", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Connections & Multiplexer",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 103,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Connection Open/Close /min",
