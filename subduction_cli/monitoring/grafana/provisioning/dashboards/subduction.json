      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (operation) (rate(subduction_storage_operation_errors_total[5m]))", "legendFormat": "{{operation}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Sedimentree Cache Miss Ratio (read paths)",
      "description": "Fraction of READ-path sedimentree resolutions (heads lookups, foreground sync, get_commits) hydrated from storage rather than the in-memory LRU. High means hydration (and its minimization) is on the read hot path. A write-through relay hits these paths rarely, so low sample counts are expected — watch it under foreground-sync load. Yellow flags a high miss ratio; green is not a 'good success rate'.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 52 },
      "id": 43,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }] } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(sum(rate(subduction_sedimentree_cache_misses_total[5m])) or vector(0)) / clamp_min((sum(rate(subduction_sedimentree_cache_hits_total[5m])) or vector(0)) + (sum(rate(subduction_sedimentree_cache_misses_total[5m])) or vector(0)), 1)", "legendFormat": "miss ratio", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sedimentree Cache Resident vs Total",
