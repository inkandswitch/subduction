    {
      "type": "timeseries",
      "title": "Handshake Outcomes /s",
      "description": "Inbound handshake attempts by outcome. Rejections (rejected/decode/io/closed) never become connections, so they're invisible in the connection counters. A spike in `rejected` can mean auth failures, clock drift, or a misbehaving/attacking client.",
