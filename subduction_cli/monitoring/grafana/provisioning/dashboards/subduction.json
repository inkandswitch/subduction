      ]
    },
    {
      "type": "timeseries",
      "title": "Slow Syncs (≥30s) /s + Successful Sync Rate",
      "description": "Rate of foreground sync rounds taking ≥30s (the long-poll queue-dwell tail) vs the total successful-sync rate. `sync_duration` records successful round-trips only — timeouts are excluded (see 'Sync Failures /s by Reason') — so the 'Sync Round Duration' quantiles are trustworthy only when 'syncs/s (success)' here is non-trivial; a scary p95 over ~0 syncs/s is a sparse-sample artifact.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 86 },
      "id": 109,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(subduction_sync_duration_seconds_bucket{le=\"+Inf\"}[5m])) - sum(rate(subduction_sync_duration_seconds_bucket{le=\"30\"}[5m]))", "legendFormat": "syncs ≥30s/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(subduction_sync_duration_seconds_count[5m]))", "legendFormat": "syncs/s (success)", "refId": "B" }
      ]
    },
