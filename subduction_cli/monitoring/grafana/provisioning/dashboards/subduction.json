    {
      "type": "timeseries",
      "title": "Log Rate by Level",
      "description": "Log volume by level. Uses the `level` stream label (promoted by Loki); case-insensitive so it works whether the deployment emits upper- or lowercase levels.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 60 },
      "id": 50,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 0, "stacking": { "mode": "normal", "group": "A" } }, "unit": "ops" }, "overrides": [{ "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }, { "matcher": { "id": "byName", "options": "warn" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }, { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }] },
