        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(subduction_storage_operation_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{operation}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(subduction_storage_operation_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{operation}}", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Storage Errors /s by Operation",
      "description": "Storage operation errors per second, by operation.",
