      "id": 100,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Active Connections",
      "description": "Current number of live peer connections (WebSocket / long-poll / iroh).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_connections_active", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Dispatch In-Flight",
      "description": "Messages currently being dispatched across all peers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 4, "y": 1 },
      "id": 2,
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 512 }, { "color": "red", "value": 900 }] }, "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_dispatch_inflight", "legendFormat": "in-flight", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Mux Pending",
      "description": "Outstanding correlated requests awaiting a response across all multiplexers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 9, "y": 1 },
      "id": 3,
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }] }, "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_mux_pending", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Dispatch Errors (5m)",
      "description": "Inbound message handlers that finished with an error in the last 5 minutes (dispatch outcome=err).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 14, "y": 1 },
      "id": 4,
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.001 }] }, "unit": "ops" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(subduction_dispatch_completed_total{outcome=~\"err|aborted\"}[5m]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Sedimentrees",
      "description": "Total sedimentrees (documents) registered in durable storage.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "none" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_storage_sedimentrees", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "Dispatch & Messages",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Dispatch In-Flight Over Time",
      "description": "Inbound messages currently being handled across all peers. Rises under load; bounded per-peer by the dispatch concurrency cap (see Dispatch Throttle).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 7 },
      "id": 10,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1, "showPoints": "never" }, "unit": "none" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_dispatch_inflight", "legendFormat": "in-flight", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dispatch Outcomes /s",
      "description": "Completed inbound-message dispatches per second, by outcome (ok / err / aborted).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 7 },
      "id": 11,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } }, "unit": "ops" }, "overrides": [{ "matcher": { "id": "byName", "options": "ok" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "err" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }, { "matcher": { "id": "byName", "options": "aborted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (outcome) (rate(subduction_dispatch_completed_total[1m]))", "legendFormat": "{{outcome}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Message Handling Latency by Type (p50 / p95 / p99)",
      "description": "Handler runtime per inbound message, by SyncMessage type (p50/p95/p99). Per-type so cheap messages (HeadsUpdate) do not blend with heavy ones (BatchSyncRequest).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 7 },
      "id": 12,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "s" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le, type) (rate(subduction_dispatch_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{type}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, type) (rate(subduction_dispatch_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{type}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le, type) (rate(subduction_dispatch_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{type}}", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Messages /s by Type",
      "description": "Inbound messages dispatched per second, by SyncMessage type.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "id": 13,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (type) (rate(subduction_messages_total[1m]))", "legendFormat": "{{type}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Batch Sync Req/Resp /s",
      "description": "BatchSyncRequest received vs BatchSyncResponse routed, per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "id": 14,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_batch_sync_requests_total[1m])", "legendFormat": "requests", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_batch_sync_responses_total[1m])", "legendFormat": "responses", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Sync Health",
