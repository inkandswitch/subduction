        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_connections_closed[5m]) * 60", "legendFormat": "closed/min", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active Connections",
      "description": "Live peer connections over time (WebSocket / long-poll / iroh).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 37 },
      "id": 31,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "showPoints": "never" }, "unit": "none" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_connections_active", "legendFormat": "active", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Multiplexer Pending & Cancels",
      "description": "Outstanding correlated requests awaiting a response (gauge), and pending requests cancelled per second (timeout/disconnect teardown).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 37 },
      "id": 32,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "none" }, "overrides": [{ "matcher": { "id": "byName", "options": "cancels/s" }, "properties": [{ "id": "unit", "value": "ops" }] }, { "matcher": { "id": "byName", "options": "requests/s" }, "properties": [{ "id": "unit", "value": "ops" }] }] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "subduction_mux_pending", "legendFormat": "pending", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_mux_requests_total[1m])", "legendFormat": "requests/s", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_mux_cancelled_total[1m])", "legendFormat": "cancels/s", "refId": "C" }
      ]
    },
    {
      "type": "row",
      "title": "Storage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
