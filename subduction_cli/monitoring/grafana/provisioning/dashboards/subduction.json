        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(subduction_dispatch_permit_wait_seconds_bucket[5m])))", "legendFormat": "permit wait p95", "refId": "B" }
