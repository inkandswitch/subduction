        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(subduction_mux_pending_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
