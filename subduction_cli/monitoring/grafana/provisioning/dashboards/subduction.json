    {
      "type": "timeseries",
      "title": "Outbound Queue Dwell by Transport (p50 / p95 / p99)",
      "description": "How long an outbound message waits in the per-connection send queue before the peer grabs it, split by transport. Long-poll dwell is gated by the client's poll cadence (up to ~30s per delivery leg, 2 legs per round-trip), so a high `longpoll` p95 alongside a near-zero `websocket` p95 means round-trip latency is client-pull wait, not sync work.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 79 },
      "id": 107,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "s" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le, transport) (rate(subduction_outbound_queue_dwell_seconds_bucket[5m])))", "legendFormat": "p50 {{transport}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, transport) (rate(subduction_outbound_queue_dwell_seconds_bucket[5m])))", "legendFormat": "p95 {{transport}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le, transport) (rate(subduction_outbound_queue_dwell_seconds_bucket[5m])))", "legendFormat": "p99 {{transport}}", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbound Queue Depth by Transport (p95)",
      "description": "Per-connection send-queue depth sampled at drain, by transport. Rising depth means a slow or absent peer is backing up its bounded (1024) channel; sustained near-capacity depth precedes send-side blocking (head-of-line stalls).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 79 },
      "id": 108,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
