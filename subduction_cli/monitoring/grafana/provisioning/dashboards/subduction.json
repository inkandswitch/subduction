      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 102,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Foreground Sync Throughput (commits/fragments per second)",
      "description": "Counts only foreground reconciliation via `sync_with_peer` (BatchSyncRequest/Response). The live subscription-push path (LooseCommit/Fragment pushed to subscribers) is NOT counted here — see the \"Subscriptions & Pushes\" panel. A push-driven server can read ~0 here while still actively moving data.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "id": 20,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_sync_commits_received_total[1m])", "legendFormat": "commits in", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_sync_commits_sent_total[1m])", "legendFormat": "commits out", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_sync_fragments_received_total[1m])", "legendFormat": "fragments in", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(subduction_sync_fragments_sent_total[1m])", "legendFormat": "fragments out", "refId": "D" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sync Round Duration (quantiles)",
      "description": "Duration of a foreground sync round (sync_with_peer), successful rounds only (p50/p95/p99). Trustworthy only when the sync rate is non-trivial — see Slow Syncs.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 12, "y": 22 },
      "id": 21,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "s" }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(subduction_sync_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(subduction_sync_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(subduction_sync_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sync Failures /s by Reason",
      "description": "Per-connection foreground sync call failures per second, by reason (timeout, dropped, ...). Timeouts excluded from Sync Round Duration land here.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 22 },
      "id": 22,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (reason) (rate(subduction_sync_call_failures_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Subscriptions & Pushes",
      "description": "Sedimentrees with at least one subscriber, and incremental update pushes to subscribers per second.",
